---
import BaseLayout from '../../layouts/BaseLayout.astro';
// const tags = ['astro', 'blogging', 'learning in public', 'successes', 'setbacks', 'community']
const allPosts = Object.values(import.meta.glob<{ frontmatter: { tags: string[] } }>('../posts/**/*.md', {eager: true}));
const tags = [...new Set(allPosts.map((post) => post.frontmatter.tags).flat())];
const pageTitle = "標簽索引";
---
<style>
  a {
    color: #00539F;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
  }

  .tag {
    margin: 0.25em;
    border: dotted 1px #a1a1a1;
    border-radius: .5em;
    padding: .5em 1em;
    font-size: 1.15em;
    background-color: #F8FCFD;
  }
</style>

<BaseLayout pageTitle={pageTitle}>
  <div class="tags">
    {tags.map((tag) => (
      <div class="tag">
        <a href={`/tags/${encodeURIComponent(tag)}`}>{tag}</a>
      </div>
    ))}
  </div>
</BaseLayout>